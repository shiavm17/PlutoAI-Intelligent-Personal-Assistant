# Pluto AI - Environment Configuration Template
# Copy this to .env and fill in your actual API keys
# DO NOT COMMIT THIS FILE TO GIT!

# ========================
# API KEYS - REQUIRED
# ========================

# Groq API (Free - https://console.groq.com/)
GroqAPIKey=gsk_your_groq_api_key_here

# Cohere API (Free tier - https://cohere.ai/)
CohereAPIKey=your_cohere_api_key_here

# OpenAI API (Requires credits - https://platform.openai.com/)
OpenAIAPIKey=sk-your_openai_api_key_here

# ========================
# SARWAM AI (NEW - TEXT & SPEECH)
# ========================

# Sarwam AI API Key (https://sarwam.com/)
# Use for high-quality Text-to-Speech (TTS) and Speech-to-Text (STT)
# If not provided, will fallback to Google Web Speech API
SarwamAPIKey=your_sarwam_api_key_here

# ========================
# BOT CONFIGURATION
# ========================

# Your name (shown in UI)
Username=User

# Bot name/assistant name
Assistantname=PlutoAI

# Voice for speech synthesis (Sarwam format: en-IN-neural, en-US-neural, etc)
AssistantVoice=en-IN-neural

# Microphone device index (usually 0 for default, run: python -c "import sounddevice as sd; print(sd.query_devices())")
MicrophoneIndex=0

# ========================
# OPTIONAL: WEB SERVER CONFIG
# ========================

# Flask server host (0.0.0.0 for network access)
FLASK_HOST=0.0.0.0

# Flask server port
FLASK_PORT=5000

# Debug mode (False for production)
FLASK_DEBUG=False

# ========================
# INSTRUCTIONS FOR USE
# ========================

# 1. Copy this file and save as ".env" in the project root
# 2. Fill in your API keys:
#    - Get Groq key from: https://console.groq.com/keys
#    - Get Cohere key from: https://dashboard.cohere.ai/
#    - Get OpenAI key from: https://platform.openai.com/account/api-keys
#    - Get Sarwam AI key from: https://sarwam.com/
# 3. Save the file
# 4. Run the application
#
# WARNING: Never commit this file! Keep your API keys secret!
# If you accidentally commit keys, regenerate them immediately.

# ========================
# TESTING YOUR KEYS
# ========================

# After creating .env, test with:
# python -c "from dotenv import dotenv_values; env = dotenv_values('.env'); print('✓ Config loaded' if env else '✗ Config failed')"
